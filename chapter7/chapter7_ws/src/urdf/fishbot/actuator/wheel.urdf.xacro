<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >
<xacro:include filename="$(find fishbot_description)/urdf/fishbot/common_inertia.xacro"/>
    <xacro:macro name="wheel_xacro" params="wheel_name xyz">
        <!-- 机器人的IMU（Inertial Measurement Unit）部件，惯性测量单元 -->
        <link name="${wheel_name}_link">
            <!-- 部件的外观描述 -->
            <visual>
                <!-- 沿着自己的几何中心的偏移和旋转 -->
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <!-- 几何形状 -->
                <geometry>
                    <cylinder radius="0.0325" length="0.04"/>
                </geometry>
                <!-- 材质颜色 -->
                <material name = "yellow">
                    <!-- rgb表示红绿蓝，范围为0～1，a表示透明度 -->
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </visual>
            <collision>
                <!-- 沿着自己的几何中心的偏移和旋转 -->
                <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
                <!-- 几何形状 -->
                <geometry>
                    <cylinder radius="0.0325" length="0.04"/>
                </geometry>
                <!-- 材质颜色 -->
                <material name = "yellow">
                    <!-- rgb表示红绿蓝，范围为0～1，a表示透明度 -->
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </collision>

            <xacro:cylinder_inertia m ="0.05" r="0.0325" h="0.04" />
        </link>

        <!-- 机器人的关节 Joint，用于组合机器人的部件 -->
        <joint name="${wheel_name}_joint" type="continuous">
            <origin xyz="${xyz}" rpy="0.0 0.0 0.0"/>
            <axis xyz="0.0 1.0 0.0"/>
            <parent link="base_link"/>
            <child link="${wheel_name}_link"/>
        </joint>

        <!-- Gazebo 配置 -->
        <gazebo reference='${wheel_name}_link'>
            <!--mu1表示切向的阻尼系数  -->
            <mu1 value= "20.0" />
            <!--mu2表示法向的阻尼系数  -->
            <mu2 value= "20.0" />
            <!--kp表示接触的刚度系数  -->
            <kp value= "1000000000.0" />
            <!--kd表示接触的阻尼系数  -->
            <kd value= "1.0" />
        </gazebo>
        
        

    </xacro:macro>
</robot>
